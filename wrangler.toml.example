# ============================================
# NavDev Wrangler 配置模板
# ============================================
# 复制此文件为 wrangler.toml 并填入你的配置
# cp wrangler.toml.example wrangler.toml
# ============================================

name = "navdev"
compatibility_date = "2024-11-11"
compatibility_flags = ["nodejs_compat"]
pages_build_output_dir = ".vercel/output/static"

# --------------------------------------------
# KV Namespace 绑定
# --------------------------------------------
# 创建命令: wrangler kv namespace create NAVDEV_KV
# 创建后将返回的 id 填入下方
[[kv_namespaces]]
binding = "NAVDEV_KV"
id = "<YOUR_KV_NAMESPACE_ID>"  # 替换为你的 KV Namespace ID

# --------------------------------------------
# R2 Bucket 绑定
# --------------------------------------------
# 创建命令: wrangler r2 bucket create navdev-assets
[[r2_buckets]]
binding = "NAVDEV_R2"
bucket_name = "navdev-assets"  # 可自定义 bucket 名称

# ============================================
# Production 环境配置
# ============================================
# 以下配置用于生产环境部署
# 部署命令: wrangler pages deploy --env production

[env.production.vars]
# 这些变量建议在 Cloudflare Dashboard 中配置
# 而不是在此文件中硬编码
# GITHUB_CLIENT_ID = ""
# GITHUB_OWNER = ""
# GITHUB_REPO = ""
# GITHUB_BRANCH = "main"
# NEXTAUTH_URL = ""
# NEXT_PUBLIC_API_URL = ""
# R2_PUBLIC_URL = ""

# Production KV Namespace
[[env.production.kv_namespaces]]
binding = "NAVDEV_KV"
id = "<YOUR_KV_NAMESPACE_ID>"  # 替换为你的 KV Namespace ID

# Production R2 Bucket
[[env.production.r2_buckets]]
binding = "NAVDEV_R2"
bucket_name = "navdev-assets"  # 可自定义 bucket 名称
