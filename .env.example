# ============================================
# NavDev 环境变量配置
# ============================================
# 复制此文件为 .env.local 并填入你的配置
# cp .env.example .env.local
# ============================================

# --------------------------------------------
# Cloudflare 配置 (用于数据迁移脚本)
# --------------------------------------------
# KV Namespace ID - 从 Cloudflare Dashboard 获取
# 创建命令: wrangler kv namespace create NAVDEV_KV
CLOUDFLARE_KV_NAMESPACE_ID=

# R2 Bucket 名称
# 创建命令: wrangler r2 bucket create navdev-assets
CLOUDFLARE_R2_BUCKET_NAME=navdev-assets

# --------------------------------------------
# GitHub OAuth App 配置 (管理员登录)
# --------------------------------------------
# 在 GitHub Settings > Developer settings > OAuth Apps 创建
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# --------------------------------------------
# GitHub 仓库配置 (用于投稿功能)
# --------------------------------------------
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name
GITHUB_BRANCH=main

# GitHub Fine-grained PAT (用于匿名投稿创建 Issue)
# 在 GitHub Settings > Developer settings > Personal access tokens 创建
GITHUB_PAT=your-github-personal-access-token

# --------------------------------------------
# NextAuth 配置
# --------------------------------------------
NEXTAUTH_URL=http://localhost:3000
# 生成方法: openssl rand -base64 32
AUTH_SECRET=your-random-auth-secret
NEXT_PUBLIC_API_URL=http://localhost:3000

# --------------------------------------------
# R2 公开访问 URL (可选)
# --------------------------------------------
# 如果配置了 R2 自定义域名，填入此处
R2_PUBLIC_URL=

# --------------------------------------------
# Google Analytics (可选)
# --------------------------------------------
GA_ID=